generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth / staff accounts
// ---------------------------------------------------------------------------

enum Role {
  ADMIN // Desktop: full dashboard, inventory CRUD, reports, warranty claims
  SALES // Mobile: POS + read-only stock lookup only
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(SALES)
  createdAt    DateTime @default(now())

  invoicesCreated Invoice[]       @relation("InvoiceCreatedBy")
  claimsHandled   WarrantyClaim[] @relation("ClaimHandledBy")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Product {
  id                String   @id @default(cuid())
  name              String
  brand             String
  category          String
  sku               String   @unique
  warrantyMonths    Int // default warranty duration applied to units sold
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  units InventoryUnit[]

  @@index([brand])
  @@index([category])
}

enum UnitStatus {
  IN_STOCK
  SOLD
  IN_REPAIR
  RETIRED // written off / scrapped, no longer sellable or repairable
}

// One row per physical, individually serialized item — never a generic quantity count.
model InventoryUnit {
  id           String     @id @default(cuid())
  productId    String
  serialNumber String     @unique
  status       UnitStatus @default(IN_STOCK)
  location     String? // shelf / bin reference for fast floor lookup
  costPrice    Decimal?   @db.Decimal(10, 2)
  receivedAt   DateTime   @default(now())

  product      Product         @relation(fields: [productId], references: [id])
  invoiceItem  InvoiceItem?
  warrantyClaims WarrantyClaim[]

  @@index([productId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Sales / billing
// ---------------------------------------------------------------------------

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique @default(cuid())
  customerName  String
  customerPhone String
  date          DateTime @default(now())
  totalAmount   Decimal  @db.Decimal(10, 2)

  createdById String?
  createdBy   User?   @relation("InvoiceCreatedBy", fields: [createdById], references: [id])

  items InvoiceItem[]

  @@index([customerPhone])
}

// Links one sold serial number to the invoice it was billed on, and freezes
// the warranty terms at time of sale so later Product edits can't retroactively
// change a customer's existing warranty.
model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String
  inventoryUnitId String   @unique
  salePrice       Decimal  @db.Decimal(10, 2)
  warrantyMonths  Int

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryUnit InventoryUnit @relation(fields: [inventoryUnitId], references: [id])

  @@index([invoiceId])
}

// ---------------------------------------------------------------------------
// Warranty claims
// ---------------------------------------------------------------------------

enum ClaimStatus {
  PENDING
  IN_REPAIR
  REPLACED
  RESOLVED
  REJECTED
}

model WarrantyClaim {
  id              String      @id @default(cuid())
  inventoryUnitId String
  dateClaimed     DateTime    @default(now())
  issueDescription String
  status          ClaimStatus @default(PENDING)
  resolutionNotes String?

  handledById String?
  handledBy   User?  @relation("ClaimHandledBy", fields: [handledById], references: [id])

  inventoryUnit InventoryUnit @relation(fields: [inventoryUnitId], references: [id])

  @@index([inventoryUnitId])
}
